pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                git 'https://github.com/YOUR_REPO_HERE'
            }
        }

        stage('Lint') {
            steps {
                sh 'flake8 app/'
            }
        }

        stage('Tests') {
            steps {
                sh 'pytest app/tests'
            }
        }

        stage('Build Docker') {
            steps {
                sh 'docker build -t youruser/devops-app:latest app/'
            }
        }

        stage('Push Docker') {
            steps {
                sh 'docker push youruser/devops-app:latest'
            }
        }

        stage('Deploy') {
            steps {
                sh '''
                ssh ubuntu@APP_SERVER_IP "
                    docker pull youruser/devops-app:latest &&
                    docker stop app || true &&
                    docker rm app || true &&
                    docker run -d --name app -p 80:80 youruser/devops-app:latest
                "
                '''
            }
        }
    }
}
